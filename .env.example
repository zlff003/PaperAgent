DASHSCOPE_API_KEY=your_api_key_here
DASHSCOPE_CHAT_MODEL=qwen-plus
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3

# 数据路径 — 开发模式下 backend 原生命令时，指回项目根目录的 data/
# Docker Compose 会自动注入自己的值覆盖这些
DATA_DIR=../data
PAPER_DIR=../data/papers
VECTOR_DIR=../data/chroma
DATABASE_URL=sqlite:///../data/paperagent.db

